@misc{basilLargeLanguageModels2024,
  type = {Scholarly {{Paper}}},
  title = {Large Language Models for Aviation Safety: {{Enhancing}} Incident Analysis through Summarization of {{ASRS}} Reports},
  author = {Basil, Ehaab},
  year = 2024,
  publisher = {University of Maryland, Department of Computer Science},
  abstract = {The growing number of reports of aircraft incidents that are sent to the Aircraft Safety Reporting System (ASRS) makes it difficult to conduct prompt and efficient analysis. Manual processing procedures that have been used traditionally are labor-intensive and time-consuming, which frequently results in delays in the identification of key safety hazards. The objective of this research is to improve the efficiency of safety analyses by automating the summarization of incident narratives through the utilization of large language models (LLMs). Furthermore, the study uses exploratory data analysis (EDA) to identify underlying safety trends, including human variables and temporal patterns, offering practical advice for enhancing airline safety procedures. A transformer-based sequence-to-sequence model is fine-tuned on 1107 incident narratives from 2018 to 2024, filtered by passenger missions and air carriers, to generate concise summaries evaluated using ROUGE scores and Sentence-BERT embeddings for semantic similarity. The proposed fine-tuned T5-Base model achieves the ROUGE-L score of 0.357 and a cosine similarity score of 0.610. The findings demonstrate that LLMs can streamline incident analysis, offering benefits such as automated summarization for rapid processing, critical risk identification through pattern analysis, and practical insights for the development of safety protocols. However, challenges such as token length truncation and computational resource constraints highlight areas for future improvement. Thus, adopting this research in real time can considerably improve aviation safety management by automating the summarizing of incident reports, allowing for the early identification of major safety issues, and easing timely decision-making procedures.},
  langid = {english},
  keywords = {RQ1,Sec-LitReview,Status-NotesComplete},
  note = {\section{Basil (2024) - Large Language Models for Aviation Safety}

\subsection{Citation}

\par
Basil, E. (2024). Large Language Models for Aviation Safety: Enhancing Incident Analysis through Summarization of ASRS Reports. University of Maryland - College Park. \href{mailto:ehaab@umd.edu}{ehaab@umd.edu}
\par
\subsection{Overview}

\par
This paper explores using fine-tuned transformer models (T5-Base and BART) to automatically summarize NASA ASRS incident narratives. The study combines LLM-based summarization with exploratory data analysis (EDA) to identify safety trends.
\par
\subsection{Key Concepts}

\subsubsection{Models Used}

\par
\textbf{T5-Base (Text-to-Text Transfer Transformer)}
\par
\begin{itemize}

\item Developed by Google Research
\item \textasciitilde 220 million parameters, 12 transformer layers
\item Frames all NLP tasks as text-to-text problems
\item Uses SentencePiece tokenizer (handles technical jargon better)

\end{itemize}

\par
\textbf{BART (Bidirectional and Auto-Regressive Transformer)}
\par
\begin{itemize}

\item Developed by Facebook/Meta
\item Combines bidirectional encoder (like BERT) with autoregressive decoder (like GPT)
\item Pre-trained via denoising (corrupting then reconstructing text)
\item Uses byte-pair encoding (BPE) tokenizer

\end{itemize}

\par
Both are \textbf{encoder-decoder sequence-to-sequence models}---smaller than modern LLMs like GPT-4 or Claude (hundreds of millions vs. hundreds of billions of parameters).
\par
\subsection{Research Questions \& Methods}

\subsubsection{RQ1: Summarization Effectiveness}

\par
\textbf{Question:} How effectively can LLMs like BART and T5-Base summarize ASRS incident narratives, and what are the limitations due to token length constraints?
\par
\textbf{Methods:}
\par
Component  Details 
\par
Dataset  1,107 ASRS reports (2018-2024), filtered for passenger missions/air carriers 
\par
Split  886 train / 110 validation / 111 test (80-10-10), stratified by flight phase 
\par
Preprocessing  Text normalization, rare class removal, token length calculation 
\par
Training  5 epochs, AdamW optimizer, learning rate 3\texttimes 10{$^{-5}$}, T4 GPU 
\par
Evaluation  ROUGE-1, ROUGE-2, ROUGE-L, Cosine Similarity (Sentence-BERT) 
\par
\subsubsection{RQ2: Safety Trends via EDA}

\par
\textbf{Question:} What safety trends can be identified through EDA, and how do they inform aviation safety protocols?
\par
\textbf{Methods:} Exploratory analysis across flight phases, temporal patterns, anomaly types, aircraft models, components, and human factors.
\par
\subsection{Evaluation Metrics Explained}

\subsubsection{ROUGE (Recall-Oriented Understudy for Gisting Evaluation)}

\par
Metric  What It Measures  Limitations 
\par
\textbf{ROUGE-1}  Single word overlap between generated and reference summary  Ignores word order; synonyms get no credit 
\par
\textbf{ROUGE-2}  Two-word phrase (bigram) overlap  Still purely lexical; no semantic understanding 
\par
\textbf{ROUGE-L}  Longest Common Subsequence---words appearing in same order (not necessarily consecutive)  Captures structure but still lexical only 
\par
\subsubsection{Cosine Similarity (Sentence-BERT)}

\par
\textbf{What it measures:} Semantic similarity---whether two texts mean the same thing regardless of word choice.
\par
\textbf{How it works:}
\par
\begin{enumerate}

\item Convert each text to a high-dimensional vector (embedding) using Sentence-BERT
\item Calculate the cosine of the angle between vectors
\item Score ranges from -1 (opposite) to 1 (identical meaning)

\end{enumerate}

\par
\textbf{Formula:} \$\textbackslash text\textbraceleft Cosine Similarity\textbraceright{} = \textbackslash frac\textbraceleft A \textbackslash cdot B\textbraceright\textbraceleft\textbar A\textbar{} \textbackslash times \textbar B\textbar\textbraceright\$
\par
\textbf{Key insight:} Unlike ROUGE, cosine similarity rewards semantic equivalence. ``Engine failure'' and ``engine malfunction'' would score high on cosine similarity despite zero bigram overlap.
\par
\subsection{Results}

\subsubsection{RQ1: Model Performance}

\par
Metric  T5-Base  BART 
\par
ROUGE-1  0.408  0.344 
\par
ROUGE-2  0.185  0.152 
\par
ROUGE-L  0.357  0.300 
\par
Cosine Similarity  0.610  0.602 
\par
\textbf{Training dynamics:} Loss decreased from 7.04 {$\rightarrow$} 0.38 over 5 epochs (good convergence)
\par
\textbf{Token limitation:} 47 narratives (4.2\%) exceeded 1024 tokens, requiring truncation
\par
\subsubsection{RQ2: EDA Findings}

\par
Dimension  Key Finding 
\par
Flight Phase  Cruise (40.7\%) and Climb (29.4\%) most incident-prone 
\par
Temporal  Sharp decline 2020-2021 (COVID), rebound 2022-2024 
\par
Anomalies  ``Aircraft Equipment Problem Critical'' dominated (856/1,107) 
\par
Components  Turbine engines most common (172 incidents) 
\par
Aircraft  B737 family = 49.9\% of incidents 
\par
Primary Problem  90.5\% aircraft equipment, only 7.2\% human factors 
\par
\subsubsection{Qualitative Issues Identified}

\par
Problem  Example 
\par
Aircraft misidentification  A321 labeled as B737-800 
\par
Human factors omitted  Fatigue/distractions absent from summaries despite being in narratives 
\par
Inconsistent performance  Cosine similarity ranged from 0.369 to 0.865 across samples 
\par
\subsection{Critical Analysis}

\subsubsection{Author's Characterization}

\begin{itemize}

\item 
\par
\textbf{Discussion:} Describes results as ``moderate performance''
\par
\item 
\par
\textbf{Conclusion:} Claims models ``effectively summarize'' ASRS reports
\par
\end{itemize}

\par
This represents rhetorical slippage---acknowledging moderate performance while claiming effectiveness.
\par
\subsubsection{Critique for Literature Review}

\begin{quotation}

\par
Basil (2024) fine-tuned T5-Base and BART models on 1,107 ASRS incident reports, achieving a best ROUGE-L score of 0.357 and cosine similarity of 0.610. While the author characterizes these results as ``moderate'' in the discussion and ``effective'' in the conclusion, this characterization warrants scrutiny in the context of safety-critical applications.
\par
A 36\% structural overlap means nearly two-thirds of the essential content or sequencing from reference summaries is not captured. More concerning, qualitative analysis revealed systematic failures: aircraft misidentification (an A321 labeled as B737-800), complete omission of human factors despite their presence in source narratives, and high variability in semantic similarity scores (ranging from 0.369 to 0.865 across test samples).
\par
For aviation safety analysis---where accurate identification of aircraft, causal factors, and human elements directly informs risk mitigation---such inconsistency represents a substantive limitation rather than moderate success. The author acknowledges these gaps but does not reconcile them with claims of effectiveness. Future work applying LLMs to safety-critical text extraction should establish domain-appropriate performance thresholds rather than benchmarking against general-purpose summarization standards.
\par
\end{quotation}

\subsubsection{Key Limitations}

\begin{enumerate}

\item 
\par
\textbf{Small dataset:} 886 training samples vs. 287,000 in CNN/DailyMail benchmark
\par
\item 
\par
\textbf{Token truncation:} 512 tokens during training, 256 during inference---longer reports lost critical details
\par
\item 
\par
\textbf{No domain-specific pre-training:} Models pre-trained on general text, not aviation corpus
\par
\item 
\par
\textbf{Human factors gap:} Both models systematically failed to extract causal human factors elements, such as fatigue and human error
\par
\item 
\par
\textbf{Inconsistent reliability:} Wide variance in cosine similarity makes individual predictions untrustworthy
\par
\end{enumerate}

\subsection{Relevance to My Research}

\subsubsection{Contrast with My Approach}

\par
Dimension  Basil (2024)  My FAA UAS Pipeline 
\par
Task  Abstractive summarization  Structured field extraction 
\par
Models  Fine-tuned T5-Base/BART (\textasciitilde 220M params)  API-based modern LLMs (instruction-tuned) 
\par
Evaluation  ROUGE, cosine similarity  Accuracy against ground truth 
\par
Best result  0.357 ROUGE-L, 0.610 cosine sim  98\% accuracy 
\par
Dataset  1,107 ASRS reports  FAA UAS sighting reports 
\par
\subsubsection{Implications}

\begin{itemize}

\item Summarization is a harder, more ambiguous task than structured extraction
\item Fine-tuning smaller models requires substantial data (this study was data-limited)
\item For safety-critical applications, ``moderate'' performance with high variance is insufficient
\item My approach (prompt engineering with modern LLMs + validation pipeline) may be more appropriate for safety data than fine-tuning smaller models

\end{itemize}

\subsection{References to Follow Up}

\begin{itemize}

\item [x] Pinon Fischer \& Mavris (2023) - ChatGPT for ASRS analysis with aeroBERT embeddings
\item [x] SafeAeroBERT (Andrade et al., 2021) - Domain-specific BERT for aviation
