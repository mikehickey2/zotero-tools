@article{isonTrackingChangesAviation2026,
  title = {Tracking Changes in Aviation Safety Narratives: {{A}} Text Mining Study of {{NTSB}} Reports (2008--2025)},
  shorttitle = {Tracking Changes in Aviation Safety Narratives},
  author = {Ison, David},
  year = 2026,
  month = jan,
  journal = {Aerospace Traffic and Safety},
  issn = {2950-3388},
  doi = {10.1016/j.aets.2025.12.006},
  urldate = {2026-01-15},
  abstract = {Accident investigation narratives provide insights into causal factors not fully captured by structured data fields. This study applied text mining, statistical comparison, and sentiment analysis to 27,000 National Transportation Safety Board (NTSB) accident and incident narratives from 2008 to 2025. The narratives were coded into seven themes: human/pilot error, mechanical/system issues, weather/environmental conditions, fuel management, loss of control/stall, runway excursion/handling events, and wildlife strikes. Comparisons between two periods (2008--2014 and 2015--2025) were conducted using chi-square tests, with linear regression applied to assess temporal trends. Correlations and network analysis were used to examine co-occurrence, while sentiment was evaluated with TextBlob on a stratified sample of 5,000 narratives. Results showed human/pilot error remained the most frequent ({$>$}90\%) but declined slightly over time, while mechanical/system issues increased and weather references decreased significantly. Runway excursion mentions increased modestly, whereas fuel, stall, and wildlife remained stable. Co-occurrence analysis revealed strong associations between human and system factors, as well as secondary links between weather, stall events, and runway excursions. Sentiment analysis confirmed consistent neutrality (polarity M = 0.02--0.03; subjectivity M {$\approx$} 0.35). The findings demonstrate both persistence and gradual shifts in narrative framing, providing evidence of evolving investigative emphases and establishing a foundation for applying natural language processing in aviation safety research.},
  keywords = {accident narratives,aviation safety,longitudinal analysis,NTSB,RQ2-Narrative,Sec-LitReview,sentiment analysis,Status-NotesComplete,text mining},
  note = {\section{Ison (2026) - Summary for Zotero}

\subsubsection{Methodology Type}

\par
\textbf{Quantitative} --- Archival, longitudinal content analysis using text mining, statistical comparison, and sentiment analysis on unstructured narrative data.
\par
\subsubsection{Research Questions Mapped to Methods, Results, \& Findings}

\par
RQ
\par
Research Question
\par
Methods
\par
Key Results
\par
Key Findings
\par
\textbf{RQ1}
\par
What are the most prevalent thematic categories in NTSB narratives (2008--2025)?
\par
Lexicon-based dictionary coding into 7 themes; descriptive statistics; N = 27,000 narratives
\par
Human/pilot error: {$>$}90\%; Mechanical/system: \textasciitilde 83\%; Weather: \textasciitilde 43\%; Runway excursion: \textasciitilde 26\%; LOC/stall: \textasciitilde 18\%; Fuel: \textasciitilde 8\%; Wildlife: \textasciitilde 3\%
\par
Human factors dominate NTSB narrative framing, consistent with prior literature characterizing "pilot error" as the primary explanatory category
\par
\textbf{RQ2}
\par
Have theme prevalence/emphasis shifted between 2008--2014 and 2015--2025?
\par
Chi-square tests of independence; Risk ratios; Cramer's V effect sizes; Benjamini-Hochberg FDR correction
\par
Weather: 50.74\% {$\rightarrow$} 41.32\% ({$\chi^2$} = 239.6, p {$<$} .001, V = 0.094); Mechanical: 73.78\% {$\rightarrow$} 83.09\% ({$\chi^2$} = 349.1, p {$<$} .001, V = 0.114); Human error: 93.81\% {$\rightarrow$} 91.23\% ({$\chi^2$} = 63.33, p {$<$} .001); Runway excursion: 10.53\% {$\rightarrow$} 14.94\% ({$\chi^2$} = 115.1, p {$<$} .001); Fuel, LOC, Wildlife: NS
\par
Significant shifts indicate evolving investigative emphasis---declining weather focus, increasing mechanical/system attention, modest reduction in sole reliance on human error framing
\par
\textbf{RQ3}
\par
What longitudinal trends exist in yearly thematic proportions?
\par
OLS linear regression on annual proportions (year as predictor)
\par
Weather: {$\beta$} = --0.011, p {$<$} .001, R{$^2$} = 0.68; Mechanical: {$\beta$} = +0.007, p {$<$} .001, R{$^2$} = 0.72; Human error, LOC, Fuel: NS trends
\par
Steady decline in weather references (\textasciitilde 1.1 pp/year) and steady increase in mechanical/system references (\textasciitilde 0.7 pp/year) over 18-year period
\par
\textbf{RQ4}
\par
How do themes co-occur, and what does this reveal about multifactorial framing?
\par
Binary correlation analysis (Pearson's r on presence/absence coding across all narratives)
\par
Human--Mechanical: r = 0.37; Human--Weather: r = 0.21; Mechanical--Weather: r = 0.19; Weather--LOC: r = 0.19; Wildlife: all r {$<$} 0.05
\par
Strong human-mechanical co-occurrence supports multifactorial causation models (Swiss cheese, TEM, HFACS); accidents rarely attributed to single factors in narrative text
\par
\subsubsection{Additional Analysis: Sentiment}

\par
Analysis
\par
Method
\par
Results
\par
Interpretation
\par
Sentiment Analysis
\par
TextBlob (lexicon-based); stratified random sample n = 5,000 (2,500 per period)
\par
Polarity: M = 0.02--0.03, SD = 0.07--0.08; Subjectivity: M {$\approx$} 0.35, SD = 0.10--0.12; Stable across years and periods
\par
Narratives maintain consistent neutral, objective tone despite thematic shifts---supports use of narrative text for automated analysis/ML applications
\par
\subsubsection{Data \& Sample}

\begin{itemize}

\item \textbf{Source:} NTSB accident/incident database (public-use)
\item \textbf{Narrative fields analyzed:} narr\_accp (accident sequence), narr\_accf (factual findings), narr\_cause (probable cause) --- concatenated
\item \textbf{Period:} January 2008 -- August 2025
\item \textbf{N:} \textasciitilde 27,000 records after exclusions
\item \textbf{Period split:} 2008--2014 (n {$\approx$} 12,000) vs. 2015--2025 (n {$\approx$} 15,000)

\end{itemize}

\subsubsection{Thematic Categories (7 themes)}

\begin{enumerate}

\item Human/Pilot Error
\item Mechanical/System Issues
\item Weather/Environmental
\item Fuel Management
\item Loss of Control (LOC)/Stall
\item Runway Excursion/Handling
\item Wildlife Strike

\end{enumerate}

\par
\emph{Validation: Dictionary validated against manual expert coding on 100-narrative sample; agreement {$>$}90\% for all categories.}
\par
\subsubsection{Key Limitations}

\begin{itemize}

\item Lexicon-based coding may miss nuanced/context-specific phrasing
\item 2014/2015 period split is arbitrary; could use change-point detection
\item Cannot distinguish genuine causation shifts from investigative practice changes
\item No comparison with structured NTSB cause codes

\end{itemize}

\subsubsection{Relevance to Dissertation}

\begin{itemize}

\item \textbf{Methodological parallel:} Applies NLP/text mining to aviation safety narratives---similar to your FAA UAS sighting report extraction work
\item \textbf{Analytical approaches:} Chi-square with FDR correction, OLS regression on proportions, correlation matrices for co-occurrence---transferable techniques
\item \textbf{Theme coding validation:} Dictionary-based approach with expert validation sample provides a model for validating your LLM extraction pipeline
\item \textbf{Longitudinal design:} Demonstrates how to structure temporal comparisons in safety narrative research

\end{itemize}

\subsubsection{Citation}

\par
Ison, D. (2026). Tracking changes in aviation safety narratives: A text mining study of NTSB reports (2008--2025). \emph{Aerospace Traffic and Safety}. https://doi.org/10.1016/j.aets.2025.12.006

