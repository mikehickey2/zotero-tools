\subsubsection{Key Findings}

\begin{itemize}

\item \textbf{LLM-assisted investigation provides rapid, systematic triage} that surfaces human-related and organizational cues early from sparse, unstructured reports
\item \textbf{Performance declines monotonically from L1{$\rightarrow$}L4}, consistent with increasing abstraction of causal constructs
\item \textbf{The approach complements (not replaces) human expertise}---AI excels at decision analysis and explicit violation detection; humans excel at psychological-state assessment
\item \textbf{Domain knowledge injection (YAML) and few-shot exemplars operate through largely independent mechanisms} (near-additive gains, only 2\% interaction effect)

\end{itemize}

\subsection{Detailed Methodological Descriptions}

\subsubsection{3.1 Quantitative Methods}

\subsubsubsection{3.1.1 Multi-Label Classification Evaluation}

\par
\textbf{Description:} Each UAV accident report can have multiple HFACS categories assigned simultaneously (18 possible categories across 4 hierarchical levels). Performance is assessed per-category with macro-averaging.
\par
\textbf{Metrics Used:}
\par
\begin{itemize}

\item \textbf{Precision:} TP/(TP+FP) - proportion of positive predictions that are correct
\item \textbf{Recall:} TP/(TP+FN) - proportion of actual positives correctly identified
\item \textbf{F1-Score:} Harmonic mean of precision and recall
\item \textbf{Accuracy:} (TP+TN)/(TP+TN+FP+FN)
\item \textbf{Macro-F1:} Unweighted average of per-category F1 scores (gives equal weight regardless of frequency)

\end{itemize}

\subsubsubsection{3.1.2 Frequency-Weighted Relevance Scoring (Pattern Extraction)}

\par
\textbf{Formula:} \$\$R\_j = \textbackslash frac\textbraceleft\textbackslash sum\_\textbraceleft i=1\textbraceright\textasciicircum\textbraceleft N\textbraceright{} f\_\textbraceleft ij\textbraceright{} w\_i\textbraceright\textbraceleft\textbackslash sum\_\textbraceleft i=1\textbraceright\textasciicircum\textbraceleft N\textbraceright{} w\_i\textbraceright\$\$
\par
Where:
\par
\begin{itemize}

\item \$R\_j\$ = normalized relevance score of pattern j
\item N = total number of reports (726)
\item \$f\_\textbraceleft ij\textbraceright\$ = binary occurrence of pattern j in report i
\item \$w\_i\$ = severity weight (1=minor incident, 3=substantial-damage accident)

\end{itemize}

\par
\textbf{Threshold:} Patterns with \$R\_j {$>$} 0.12\$ retained (35 initial {$\rightarrow$} 26 consolidated)
\par
\subsubsubsection{3.1.3 Inter-Rater Reliability (Fleiss' Kappa)}

\par
\textbf{Formula:} \$\$\textbackslash kappa = \textbackslash frac\textbraceleft\textbackslash bar\textbraceleft P\textbraceright\_o - \textbackslash bar\textbraceleft P\textbraceright\_e\textbraceright\textbraceleft 1 - \textbackslash bar\textbraceleft P\textbraceright\_e\textbraceright\$\$
\par
\textbf{Result:} {$\kappa$} = 0.82 (95\% CI: 0.65-0.92) --- "substantial agreement" on Landis-Koch scale
\par
\subsubsubsection{3.1.4 Consensus Index (Delphi Round 2)}

\par
\textbf{Formula:} \$\$CI\_p = 1 - \textbackslash frac\textbraceleft IQR\_p\textbraceright\textbraceleft R\_\textbraceleft scale\textbraceright\textbraceright\$\$
\par
Where:
\par
\begin{itemize}

\item \$CI\_p\$ = consensus index for pattern p
\item \$IQR\_p\$ = inter-quartile range of re-ratings
\item \$R\_\textbraceleft scale\textbraceright\$ = 4 (effective width of 1-5 scale)

\end{itemize}

\par
\textbf{Threshold:} Consensus declared when \$CI\_p {$\geq$} 0.75\$ (IQR {$\leq$} 1)
\par
\subsubsubsection{3.1.5 Content Validity Ratio (Lawshe's CVR)}

\par
\textbf{Formula:} \$\$CVR\_p = \textbackslash frac\textbraceleft n\_\textbraceleft ep\textbraceright{} - N/2\textbraceright\textbraceleft N/2\textbraceright\$\$
\par
Where:
\par
\begin{itemize}

\item \$n\_\textbraceleft ep\textbraceright\$ = number of experts rating pattern p as essential ({$\geq$}4 on 5-point scale)
\item N = total experts (5)

\end{itemize}

\par
\textbf{Result:} Mean CVR = 0.72; 21/26 patterns (80.8\%) met critical cutoff of 0.60
\par
\subsubsubsection{3.1.6 Confidence-Weighted Pattern Matching (LLM Integration)}

\par
\textbf{Formula:} \$\$S(T, P\_i) = \textbackslash alpha \textbackslash cdot f\_\textbraceleft sem\textbraceright (T, D\_i) + \textbackslash beta \textbackslash cdot f\_\textbraceleft ind\textbraceright (T, I\_i) + \textbackslash gamma \textbackslash cdot f\_\textbraceleft ctx\textbraceright (T, C\_i)\$\$
\par
Where:
\par
\begin{itemize}

\item \$f\_\textbraceleft sem\textbraceright\$ = semantic similarity between narrative T and pattern definition D
\item \$f\_\textbraceleft ind\textbraceright\$ = indicator matching function
\item \$f\_\textbraceleft ctx\textbraceright\$ = contextual relevance function
\item {$\alpha$}, {$\beta$}, {$\gamma$} = weighting parameters

\end{itemize}

\par
\textbf{Output:} S(T, P\_i) ranges 0-1; higher values = stronger pattern activation
\par
\subsubsubsection{3.1.7 Multi-Dimensional Quality Assessment}

\par
\textbf{Formula:} \$\$Q\_\textbraceleft cls\textbraceright{} = 0.3 \textbackslash cdot Q\_\textbraceleft conf\textbraceright{} + 0.3 \textbackslash cdot Q\_\textbraceleft evid\textbraceright{} + 0.2 \textbackslash cdot Q\_\textbraceleft reas\textbraceright{} + 0.2 \textbackslash cdot Q\_\textbraceleft cons\textbraceright\$\$
\par
Where:
\par
\begin{itemize}

\item \$Q\_\textbraceleft conf\textbraceright\$ = confidence appropriateness (alignment with evidence strength)
\item \$Q\_\textbraceleft evid\textbraceright\$ = evidence quality (specificity, relevance of citations)
\item \$Q\_\textbraceleft reas\textbraceright\$ = reasoning quality (logical coherence, narrative references)
\item \$Q\_\textbraceleft cons\textbraceright\$ = category-layer consistency (HFACS hierarchical alignment)

\end{itemize}

\subsubsection{3.2 Qualitative Methods}

\subsubsubsection{3.2.1 Thematic Analysis (Braun \& Clarke, 2006)}

\par
\textbf{Description:} Systematic approach to identifying, analyzing, and reporting patterns within qualitative data. Used both inductive (data-driven) and deductive (theory-driven) coding approaches.
\par
\textbf{Application:} Initial codes derived from existing HFACS categories; emergent codes identified through systematic review of 726 incident narratives.
\par
\subsubsubsection{3.2.2 Delphi Technique (Two-Round)}

\par
\textbf{Description:} Structured group communication method using iterative rounds of questionnaires with controlled feedback to achieve expert consensus.
\par
\textbf{Panel:} 5 domain specialists with 7-15 years UAV/human factors experience:
\par
\begin{itemize}

\item 2 certified remote pilots
\item 1 aviation safety analyst
\item 1 automation researcher
\item 1 regulatory-compliance engineer

\end{itemize}

\par
\textbf{Round 1:} Rated each pattern on theoretical relevance, practical significance, definitional clarity (5-point Likert). Patterns with mean {$\geq$}3.8 advanced.
\par
\textbf{Round 2:} Re-rated items with initial {$\kappa$} {$<$} 0.70 after reviewing anonymized feedback.
\par
\subsubsubsection{3.2.3 Theoretical Mapping Validation}

\par
\textbf{Description:} Alternative to factor analysis when sample size is insufficient. Each pattern systematically mapped to corresponding HFACS level with expert consensus verification.
\par
\textbf{Result:} 96\% expert consensus on HFACS mapping
\par
\subsubsubsection{3.2.4 Error Pattern Analysis}

\par
\textbf{Description:} Qualitative categorization of model prediction errors into distinct patterns to guide improvements.
\par
\textbf{Categories Identified:}
\par
\begin{itemize}

\item \textbf{Hallucinations (FP):} Category confusion (66.1\%), Level confusion (32.6\%), Spurious detection (1.3\%)
\item \textbf{Omissions (FN):} Organizational blindness (37.5\%), Supervisory omission (26.5\%), Other (36.1\%)

\end{itemize}

\par
\subsection{LLM Training/Fine-Tuning/Prompt Engineering Phases and Steps}

\subsubsection{4.1 Phase Overview}

\par
The authors used a \textbf{structured prompting framework} with \textbf{lightweight post-processing}---NOT traditional fine-tuning. The LLMs were used in their pre-trained state with carefully engineered prompts and domain knowledge injection.
\par
\subsubsection{4.2 HFACS-UAV Framework Development (Pre-LLM)}

\subsubsubsection{Phase 1: Data Acquisition and Screening}

\par
\textbf{Steps:}
\par
\begin{enumerate}

\item Harvested 847 small-UAS occurrence reports from ASRS and NTSB (Jan 2010 - May 2025)
\item Applied inclusion criteria: Human-operator involvement (H=1), Narrative detail score {$\geq$}3, Causal statements present (C=1)
\item Dual-assessor screening with Cohen's {$\kappa$} = 0.78
\item \textbf{Output:} 726 eligible reports (85.7\% retention)

\end{enumerate}

\subsubsubsection{Phase 2: Knowledge Synthesis and Pattern Extraction}

\par
\textbf{Steps:}
\par
\begin{enumerate}

\item Conducted thematic analysis per Braun \& Clarke (2006)
\item Used both inductive (data-driven) and deductive (HFACS-based) coding
\item Applied frequency-weighted relevance scoring
\item Set empirical threshold (R\_j {$>$} 0.12)
\item Iterative team refinement
\item \textbf{Output:} 26 UAV-specific enhancement patterns

\end{enumerate}

\subsubsubsection{Phase 3: Expert Validation}

\par
\textbf{Steps:}
\par
\begin{enumerate}

\item Engaged 5 domain experts for two-round Delphi
\item Round 1: Rate patterns on 3 criteria (5-point Likert)
\item Calculated composite scores; retained patterns with mean {$\geq$}3.8
\item Round 2: Re-rated items with {$\kappa$} {$<$} 0.70 after anonymized feedback
\item Measured consensus using IQR index
\item \textbf{Output:} Expert-validated 26 patterns (CI mean = 0.83)

\end{enumerate}

\subsubsubsection{Phase 4: Statistical Validation}

\par
\textbf{Steps:}
\par
\begin{enumerate}

\item Calculated Lawshe's CVR for content validity
\item Performed theoretical mapping validation (since n too small for factor analysis)
\item Computed pattern-level agreement metrics
\item \textbf{Output:} Validated HFACS-UAV framework

\end{enumerate}

\subsubsection{4.3 LLM Integration Architecture (3 Stages)}

\subsubsubsection{Stage 1: Architectural Design}

\par
\textbf{Components:}
\par
\begin{itemize}

\item Preserved HFACS 8.0 taxonomy (4 levels, 18 categories) with NO deletions/renamings
\item Added UAV-specific factors as additive extensions mapped to parent categories
\item Enabled selective activation, backward compatibility, and parallel causal reasoning

\end{itemize}

\subsubsubsection{Stage 2: Pattern Encoding}

\par
\textbf{Each pattern P\_i defined as:} \$\$P\_i = \textbackslash langle D\_i, I\_i, M\_i, R\_i, C\_i \textbackslash rangle\$\$
\par
Where:
\par
\begin{itemize}

\item D = definition
\item I = empirical indicators
\item M = HFACS mappings
\item R = inter-pattern relations
\item C = activation constraints

\end{itemize}

\par
\textbf{Directed-graph relations} G = (V, E) enable causal-chain reconstruction using do-calculus reasoning.
\par
\subsubsubsection{Stage 3: LLM Integration}

\par
\textbf{Structured Prompt Engineering Components:}
\par
\begin{enumerate}

\item 
\par
\textbf{Domain Knowledge Injection D(K\_UAV)}
\par
\begin{itemize}

\item 
\par
YAML-based knowledge base containing:
\par
\begin{itemize}

\item Definitions of all 18 HFACS categories
\item UAV-specific exemplars from real accident cases
\item Hierarchical L1-L4 mapping
\item 600+ technical terms
\item 28 UAV-specific risk factors
\item Regulatory frameworks

\end{itemize}

\end{itemize}

\item 
\par
\textbf{Task Decomposition T(x)}
\par
\begin{itemize}

\item Breaks complex HFACS classification into sequential reasoning steps
\item Guides LLM through systematic evaluation of each category
\item Explicit reasoning chains required

\end{itemize}

\item 
\par
\textbf{Evidence Binding E(x)}
\par
\begin{itemize}

\item 
\par
Structured assessment protocol with explicit confidence scoring:
\par
\begin{itemize}

\item 0.9-1.0: Explicit textual statements
\item 0.7-0.8: Strong indirect evidence
\item 0.5-0.6: Moderate implications
\item 0.3-0.4: Weak indicators
\item 0.1-0.2: Very weak/speculative evidence

\end{itemize}

\end{itemize}

\item 
\par
\textbf{Confidence Quantification Q(x)}
\par
\begin{itemize}

\item Multi-dimensional quality assessment (see formula in Section 3.1.7)
\item Threshold for human review: {$<$}0.5 individual, {$<$}0.6 overall

\end{itemize}

\end{enumerate}

\subsubsection{4.4 Three-Stage HFACS Reasoning Procedure}

\par
\textbf{Stage 1 - Unsafe Acts Classification:}
\par
\begin{itemize}

\item Determine if actions represent: skill-based error, judgment/decision-making error, perceptual error, or deliberate violation
\item Each classification explicitly grounded in cited narrative evidence

\end{itemize}

\par
\textbf{Stage 2 - Preconditions Inference:}
\par
\begin{itemize}

\item Infer enabling preconditions (especially UAV-centric technological/physical environment factors)
\item Anchor to report text
\item Condition on (but not dictate by) structured ASRS fields

\end{itemize}

\par
\textbf{Stage 3 - Higher Tier Analysis:}
\par
\begin{itemize}

\item Identify contributory supervisory and organizational influences
\item Complete multi-level HFACS reasoning process
\item Apply cross-level consistency checks

\end{itemize}

\subsubsection{4.5 Prompting Strategy Details}

\subsubsubsection{Few-Shot Learning Approach}

\par
\textbf{Exemplar Selection Criteria:}
\par
\begin{itemize}

\item Diverse UAV contexts
\item Varying complexity (single- vs. multi-factor incidents)
\item Explicit contrasts across categories
\item Balanced coverage across HFACS layers
\item Drawn from pool disjoint from evaluation set (prevents leakage)

\end{itemize}

\subsubsubsection{YAML Knowledge Base Contents}

\begin{itemize}

\item Machine-readable yet human-auditable
\item Enables grounding predictions in codified safety taxonomies
\item Separates domain knowledge from inference process

\end{itemize}

\subsubsubsection{Inference Parameters (All Models)}

\begin{itemize}

\item Temperature: 0.1
\item Max tokens: 2,048
\item Top-p: 0.9

\end{itemize}

\subsubsection{4.6 Human-in-the-Loop Integration}

\par
\textbf{Intelligent Information Completion Workflow:}
\par
\begin{enumerate}

\item Witness submits oral narrative via smart reporting interface
\item LLM performs extraction, assigns confidence to each field
\item System tracks completeness of ASRS form
\item For insufficient completeness: LLM generates targeted completion questions
\item Questions returned to witness for clarification
\item Human investigator reviews preliminary extraction
\item Witness answers/edits {$\rightarrow$} system integrates and re-scores
\item Human investigator performs final confirmation
\item Record proceeds to HFACS analysis

\end{enumerate}

\par
\textbf{Confidence Thresholds for Human Review:}
\par
\begin{itemize}

\item Individual classification: {$<$}0.5
\item Overall analysis: {$<$}0.6

\end{itemize}

