@article{yanUAVAccidentForensics2025,
  title = {{{UAV}} Accident Forensics via {{HFACS-LLM}} Reasoning: {{Low-altitude}} Safety Insights},
  shorttitle = {{{UAV Accident Forensics}} via {{HFACS-LLM Reasoning}}},
  author = {Yan, Yuqi and Li, Boyang and Lodewijks, Gabriel},
  year = 2025,
  month = oct,
  journal = {Drones},
  volume = {9},
  number = {10},
  pages = {704},
  issn = {2504-446X},
  doi = {10.3390/drones9100704},
  urldate = {2026-01-17},
  abstract = {UAV accident investigation is essential for safeguarding the fast-growing low-altitude airspace. While near-daily incidents are reported, they were rarely analyzed in depth as current inquiries remain expert-dependent and time-consuming. Because most jurisdictions mandate formal reporting only for serious injury or substantial property damage, a large proportion of minor occurrences receive no systematic investigation, resulting in persistent data gaps and hindering proactive risk management. This study explores the potential of using large language models (LLMs) to expedite UAV accident investigations by extracting human-factor insights from unstructured narrative incident reports. Despite their promise, the off-the-shelf LLMs still struggle with domain-specific reasoning in the UAV context. To address this, we developed a human factors analysis and classification system (HFACS)-guided analytical framework, which blends structured prompting with lightweight post-processing. This framework systematically guides the model through a two-stage procedure to infer operators' unsafe acts, their latent preconditions, and the associated organizational influences and regulatory risk factors. A HFACS-labelled UAV accident corpus comprising 200 abnormal event reports with 3600 coded instances has been compiled to support evaluation. Across seven LLMs and 18 HFACS categories, macro-F1 ranged 0.58--0.76; our best configuration achieved macro-F1 0.76 (precision 0.71, recall 0.82), with representative category accuracies {$>$} 93\%. Comparative assessments indicate that the prompted LLM can match, and in certain tasks surpass, human experts. The findings highlight the promise of automated human factor analysis for conducting rapid and systematic UAV accident investigations.},
  langid = {english},
  keywords = {RQ1,Sec-LitReview,Status-NotesComplete},
  note = {\section{Yan et al. (2025) ~}

\section{UAV Accident Forensics via HFACS-LLM Reasoning: Low-Altitude Safety Insights}

\par
\textbf{Relevance\\
}This article is EXTREMELY relevant to my dissertation research on the FAA UAS Sighting Reports Database. The authors have developed a comprehensive methodology for extracting structured human factors data from unstructured aviation safety narratives using LLM-assisted extraction---directly parallel to my own research objectives.
\par
\textbf{DEEP-DIVE THE FOLLOWING:}
\par
\begin{itemize}

\item [ ] The HFACS-guided prompting framework and evidence binding approach
\item [ ] The YAML-based knowledge injection methodology
\item [ ] The few-shot learning strategy with domain-specific exemplars
\item [ ] The multi-dimensional quality assessment scoring system
\item [ ] The confidence calibration protocol (0.1-1.0 scale)
\item [ ] The human-in-the-loop validation workflow
\item [ ] The ablation study design demonstrating component contributions
\item [ ] Their dataset construction and annotation methodology (directly applicable to my ASRS-based work)

\end{itemize}

\subsection{Links}

\begin{itemize}

\item \textbf{Prototype Application:} https://uav-accident-forensics.streamlit.app/
\item \textbf{GitHub Repository:} https://github.com/YukeyYan/UAV-Accident-Forensics-HFACS-LLM

\end{itemize}

\par
This study develops an LLM-assisted system for UAV accident investigation that extracts human factors insights from unstructured ASRS narrative reports using a Human Factors Analysis and Classification System (HFACS)-guided analytical framework. The system achieved macro-F1 scores ranging from 0.58-0.76 across seven LLMs and 18 HFACS categories, with the best configuration (GPT-4o-mini) achieving macro-F1 of 0.76 (precision 0.71, recall 0.82).
\par
\subsection{Research Question {$\rightarrow$} Methods {$\rightarrow$} Results {$\rightarrow$} Findings Mapping}

\subsubsection{2.1 Research Questions}

\par
RQ\#
\par
Research Question
\par
RQ1
\par
Can LLMs effectively extract human-factor insights from unstructured UAV accident narratives?
\par
RQ2
\par
How can the HFACS framework be adapted for UAV-specific operational contexts?
\par
RQ3
\par
What prompt engineering strategies optimize LLM performance for domain-specific accident classification?
\par
RQ4
\par
How does LLM performance compare to human expert assessment in HFACS classification?
\par
\subsubsection{2.2 Methods-to-Questions Mapping}

\par
Research Question
\par
Primary Methods Applied
\par
RQ1
\par
Multi-label classification evaluation, macro-F1/precision/recall metrics, 7 LLM comparison
\par
RQ2
\par
4-phase HFACS-UAV framework development, Delphi expert validation, thematic analysis
\par
RQ3
\par
2\texttimes 2 ablation study (YAML knowledge + few-shot), structured prompt engineering
\par
RQ4
\par
Human-expert benchmark comparison on L1/L2 categories, F1 score analysis
\par
