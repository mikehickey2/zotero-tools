@article{wallaceEvaluatingSmallUAS2018,
  title = {Evaluating Small {{UAS}} near Midair Collision Risk Using {{AeroScope}} and {{ADS-B}}},
  author = {Wallace, Ryan and Kiernan, Kristy and Haritos, Tom and Robbins, John and D'souza, Godfrey},
  year = 2018,
  month = jan,
  journal = {International Journal of Aviation, Aeronautics, and Aerospace},
  volume = {5},
  number = {4},
  issn = {2374-6793},
  doi = {10.15394/ijaaa.2018.1268},
  keywords = {Sec-Background,Status-NotesComplete},
  note = {\textbf{Novel reproducible methodology using system captured data:}
\par
\begin{itemize}

\item 
\par
Utilized applied research method combining exploratory research and case study approaches
\par
\item 
\par
Deployed DJI AeroScope detection system mounted on a three-story building near Daytona Beach International Airport (KDAB) for a 13-day data collection period
\par
\item 
\par
Evaluated detection data to establish: number of individual UAS flights, census of unique platforms, operating locations, and maximum flight altitudes
\par
\item 
\par
Assessed temporal factors including day/time distribution of sUAS operations
\par
\item 
\par
Conducted under institutional review board protocols for human subjects protection
\par
\item 
\par
Converted geolocation coordinates to KML datasets using EasyMapMaker online tool for import into Google Earth Pro
\par
\item 
\par
Integrated multiple georeferenced overlays for spatial analysis:
\par
\begin{itemize}

\item Jacksonville Raster Charts (FAA aeronautical data)
\item AirNav site data for private heliport locations
\item Google Maps for identifying proximate operating locations
\item DJI Fly Safe Geo Zone Map data for geofencing effectiveness assessment

\end{itemize}

\item 
\par
Correlated UAS flight detection times with historical ADS-B data via Symphony OpsVue (Harris Corporation) to assess manned aircraft proximity

Data Collection Period
\par
\item 
\par
May 17--29, 2018 (13 days)\\
Location: Daytona Beach International Airport (DAB) and surrounding area\#\# AeroScope Detection Findings
\par
\begin{itemize}

\item 
\par
192 sUAS flights detected (73 unique DJI platfo\\
rms)
\par
\item 
\par
126 flights (66\%) within Class C airspace
\par
\item 
\par
38 flights (21.5\%) exceeded UAS Facility Map altitude limits
\par
\item 
\par
2 near midair collision events documented
\par
\begin{itemize}

\item Banner tow aircraft: sUAS at 462 ft within 0.30 NM, second aircraft co-altitude
\item Runway 7L approach: sUAS at 90 ft within 0.25 NM of approach path

\end{itemize}

\end{itemize}

\subsection{Voluntary Reporting Comparison (May 2018)}

\par
Source  UAS-Related Reports 
\par
FAA Drone Sighting Database  0 
\par
NASA ASRS  0 
\par
Note: One ASRS report filed in the area during this period was unrelated (ATC transponder issue).\#\# SignificanceSensor-based detection identified substantial unauthorized UAS activity and two near midair collisions. Voluntary reporting systems captured none of this activity, suggesting self-reported data significantly underrepresents actual UAS risk exposure in the National Airspace System.``The device collects, decodes, and records existing datalink communication signals exchanged between the sUAS remote controller and the aerial platform (DJI, 2017)'' (\href{zotero://select/groups/6042289/items/YE8GMY4Y}{Wallace et al., 2018, p. 3})``aerial vehicle location, remote controller location, home point, vector, altitude, speed, serial identification, and other parameters (DJI, 2017)'' (\href{zotero://select/groups/6042289/items/YE8GMY4Y}{Wallace et al., 2018, p. 4})``AeroScope device only detects DJI-manufactured platforms'' (\href{zotero://select/groups/6042289/items/YE8GMY4Y}{Wallace et al., 2018, p. 4})``eroScope device detects only platforms within electronic line-ofsight'' (\href{zotero://select/groups/6042289/items/YE8GMY4Y}{Wallace et al., 2018, p. 4})``unable to assess which operational ruleset individual sUAS platforms were operating under'' (\href{zotero://select/groups/6042289/items/YE8GMY4Y}{Wallace et al., 2018, p. 4})
\par
\item 
\par
``The AeroScope was deployed on an educational building adjacent to Daytona Beach International Airport from May 17, 2018 through May 29, 2018.'' (\href{zotero://select/groups/6042289/items/YE8GMY4Y}{Wallace et al., 2018, p. 4})\href{zotero://open/groups/6042289/items/VRASINYF?page=7&annotation=52EF5JV9}{``On average, the most prevalent flying days were detected mid-week on Wednesdays and Thursdays. The mean detection rate for Wednesday was 29 flights-per-day and Thursday was 21.5 flights-per-day. It is likely that these results may be highly skewed due to the limited collection window, as well as other seasonal or temporal factors not considered within the scope of this study.''} (\href{zotero://select/groups/6042289/items/YE8GMY4Y}{Wallace et al., 2018, p. 5}) This conflicts with other studies that mention Saturdays and Sundays as the most prevalent UAS flying days.\href{zotero://open/groups/6042289/items/VRASINYF?page=7&annotation=LVIR7MLJ}{``preponderance of flight activity---nearly 17.3\%--occurred between the hours of 19:00-20:00L. The mean detection time was 15:48L, with the median detection time being 16:48L.''} (\href{zotero://select/groups/6042289/items/YE8GMY4Y}{Wallace et al., 2018, p. 5})\href{zotero://open/groups/6042289/items/VRASINYF?page=8&annotation=MHSPMZXE}{``UAS flights were detected at altitudes ranging from ground level to as high as 1,286 feet AGL. UAS operated at a mean altitude of 238 feet AGL and a median altitude of 195 feet AGL.''} (\href{zotero://select/groups/6042289/items/YE8GMY4Y}{Wallace et al., 2018, p. 6})\\
This range analysis of UAS flying conflicts with the the prevalance of reports in the Drone Sightings Database.

\#\#\# Potential Altitude Reporting Bias \#\#\#AeroScope detected mean/median altitudes of 238/195 ft AGL, with only 6.8\% exceeding 400 ft AGL. Pilot-based sighting reports inherently bias toward higher-altitude encounters where manned aircraft operate, leaving the majority of low-altitude UAS activity unrepresented in voluntary reporting systems.
\par
\end{itemize}},
  file = {/Users/mikehickey2/Zotero/storage/VRASINYF/Wallace et al. - 2018 - Evaluating Small UAS Near Midair Collision Risk Using AeroScope and ADS-B.pdf;/Users/mikehickey2/Zotero/storage/FTIRJ6FY/2.html}
}

