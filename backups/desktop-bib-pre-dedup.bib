\begin{itemize}

\item Trustworthiness/explainability of AI models
\item Regulatory barriers and certification frameworks
\item Human-AI interaction design
\item Dataset quality, privacy, and representativeness

\end{itemize}

\item \textbf{Recommendations:} Explainable AI (XAI), hybrid intelligence design, diversified datasets, AI certification frameworks

\end{enumerate}

\subsubsection{Methodology}

\begin{itemize}

\item PRISMA-based systematic review
\item Content analysis for domain/model mapping
\item Thematic analysis for challenge identification

\end{itemize}

